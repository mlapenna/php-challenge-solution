{
  "name": "assessment/php-mysql-visitor-analytics",
  "description": "Starter repository for a PHP and MySQL visitor analytics assessment.",
  "type": "project",
  "license": "proprietary",
  "require": {
    "php": "^8.3",
    "ext-json": "*",
    "ext-pdo": "*",
    "ext-pdo_mysql": "*",
    "slim/psr7": "^1.7",
    "slim/slim": "^4.14"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.5"
  },
  "autoload": {
    "psr-4": {
      "Challenge\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Challenge\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit",
    "start": "php -S 0.0.0.0:8080 -t public public/index.php"
  },
  "config": {
    "sort-packages": true
  }
}

